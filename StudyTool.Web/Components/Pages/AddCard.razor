@page "/cards/add"
@rendermode InteractiveServer

<div class="p-6 max-w-2xl">
    <div class="flex items-center gap-3 mb-6">
        <a href="/" class="text-sm text-gray-400 hover:text-gray-600">← Library</a>
        <span class="text-gray-200">/</span>
        <h1 class="text-lg font-medium text-gray-900">Add card</h1>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="text-sm text-red-600 bg-red-50 px-4 py-3 rounded-lg mb-4">
            @errorMessage
        </div>
    }

    @if (saveSuccess)
    {
        <div class="text-sm text-green-700 bg-green-50 px-4 py-3 rounded-lg mb-4">
            Card saved. <a href="/" class="underline">Back to library</a> or continue adding cards.
        </div>
    }

    <div class="bg-white border border-gray-200 rounded-xl p-6 flex flex-col gap-5">

        <div>
            <label class="block text-xs text-gray-500 uppercase tracking-wide mb-1.5">Group</label>
            <select @bind="selectedGroupId"
                    class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2 outline-none focus:border-orange-400 bg-white text-gray-900">
                <option value="">Select a group...</option>
                @foreach (var group in groups)
                {
                    <option value="@group.Id">@group.Name</option>
                }
            </select>
            @if (showNewGroup)
            {
                <input @bind="newGroupName" placeholder="New group name..."
                       class="mt-2 w-full text-sm border border-gray-200 rounded-lg px-3 py-2 outline-none focus:border-orange-400" />
            }
            <button @onclick="ToggleNewGroup"
                    class="mt-1.5 text-xs text-orange-600 hover:text-orange-700">
                @(showNewGroup ? "Cancel new group" : "+ Create new group")
            </button>
        </div>

        <div>
            <label class="block text-xs text-gray-500 uppercase tracking-wide mb-1.5">Question</label>
            <input @bind="title" placeholder="What question do you want to practise?"
                   class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2 outline-none focus:border-orange-400" />
        </div>

        <div>
            <label class="block text-xs text-gray-500 uppercase tracking-wide mb-1.5">Answer</label>
            <textarea @bind="content" rows="6" placeholder="Write your ideal answer here..."
                      class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2 outline-none focus:border-orange-400 resize-none"></textarea>
        </div>

        <div>
            <label class="block text-xs text-gray-500 uppercase tracking-wide mb-1.5">Image (optional)</label>
            <InputFile OnChange="OnImageSelected" accept="image/*"
                       class="text-sm text-gray-500" />
            @if (!string.IsNullOrEmpty(imagePreview))
            {
                <img src="@imagePreview" alt="Preview" class="mt-3 max-h-48 rounded-lg border border-gray-200" />
            }
        </div>

        <div class="flex items-center justify-between pt-2 border-t border-gray-100">
            <label class="flex items-center gap-2 cursor-pointer">
                <input type="checkbox" @bind="flaggedForImprovement" class="rounded" />
                <span class="text-sm text-gray-600">Flag for improvement</span>
            </label>
            <div class="flex gap-3">
                <a href="/" class="text-sm text-gray-400 hover:text-gray-600 px-4 py-2">Cancel</a>
                <button @onclick="SaveCard" disabled="@isSaving"
                        class="bg-orange-600 text-white text-sm px-5 py-2 rounded-lg hover:bg-orange-700 disabled:opacity-50">
                    @(isSaving ? "Saving..." : "Save card")
                </button>
            </div>
        </div>
    </div>
</div>